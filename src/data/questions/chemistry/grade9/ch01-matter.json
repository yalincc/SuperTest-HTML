      "stem": "下列关于原子的说法正确的是（  ）",
      "options": [
        { "label": "A", "text": "原子是不可再分的最小粒子" },
        { "label": "B", "text": "原子核由质子和电子组成" },
        { "label": "C", "text": "原子中质子数等于核外电子数" },
        { "label": "D", "text": "所有原子的原子核中都有中子" }
      ],
      "answer": "C",
      "difficulty": 2,
      "topicId": "chem-g9-ch01-t02",
