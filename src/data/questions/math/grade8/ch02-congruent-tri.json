          { "op": "midpoint", "id": "D", "of": ["A", "B"] },
          { "op": "ratio_point", "id": "E", "from": "B", "to": "C", "ratio": 0.39 },
          { "op": "segment", "from": "D", "to": "E", "style": "dashed" },
