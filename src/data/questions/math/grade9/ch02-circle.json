    {
      "id": "math-g9-ch02-q001",
      "type": "choice",
      "stem": "如图，圆O的半径为5，弦AB=6，OC⊥AB于C。则OC的长度为（  ）",
      "options": [
        { "label": "A", "text": "$3$" },
        { "label": "B", "text": "$4$" },
        { "label": "C", "text": "$\\sqrt{11}$" },
        { "label": "D", "text": "$5$" }
      ],
      "answer": "B",
      "difficulty": 2,
      "topicId": "math-g9-ch02-t01",
      "tags": ["基础题"],
      "figure": {
        "type": "construction",
        "padding": 1.2,
        "construction": [
          { "op": "point", "id": "O", "at": [0, 0] },
          { "op": "point", "id": "A", "at": [-3, -4] },
          { "op": "point", "id": "B", "at": [3, -4] },
          { "op": "circle", "id": "circleO", "center": "O", "through": "A" },
          { "op": "segment", "from": "A", "to": "B", "label": "6" },
          { "op": "foot", "id": "C", "point": "O", "line": ["A", "B"] },
          { "op": "segment", "from": "O", "to": "C", "style": "dashed", "label": "OC" },
          { "op": "segment", "from": "O", "to": "A", "style": "dashed", "label": "r" },
          { "op": "angle_mark", "vertex": "C", "p1": "O", "p2": "B", "right": true }
        ]
      },
      "solution": {
        "answer": "B",
        "steps": [
          { "description": "因为 OC⊥AB，所以 C 是 AB 的中点（垂径定理）" },
          { "description": "$AC = \\dfrac{AB}{2} = 3$" },
          { "description": "在 Rt△OAC 中：$OC = \\sqrt{OA^2 - AC^2} = \\sqrt{25 - 9} = \\sqrt{16} = 4$" }
        ],
        "keyKnowledge": "垂径定理、勾股定理"
      }
    },
    {
      "id": "math-g9-ch02-q002",
      "type": "choice",
      "stem": "如图，PA是圆O的切线，A为切点，PO交圆O于B，PA=4，PB=2。则圆O的半径为（  ）",
      "options": [
        { "label": "A", "text": "$2$" },
        { "label": "B", "text": "$3$" },
        { "label": "C", "text": "$4$" },
        { "label": "D", "text": "$5$" }
      ],
      "answer": "B",
      "difficulty": 3,
      "topicId": "math-g9-ch02-t02",
      "tags": ["提高题"],
      "figure": {
        "type": "construction",
        "padding": 1.2,
        "construction": [
          { "op": "point", "id": "O", "at": [0, 0] },
          { "op": "point", "id": "B", "at": [-3, 0] },
          { "op": "circle", "id": "circleO", "center": "O", "through": "B" },
          { "op": "point", "id": "P", "at": [-5, 0] },
          { "op": "point", "id": "A", "at": [-1.8, 2.4] },
          { "op": "segment", "from": "P", "to": "A", "label": "4" },
          { "op": "segment", "from": "P", "to": "O", "style": "solid" },
          { "op": "segment", "from": "O", "to": "A", "style": "dashed", "label": "r" },
          { "op": "angle_mark", "vertex": "A", "p1": "P", "p2": "O", "right": true }
        ]
      },
      "solution": {
        "answer": "B",
        "steps": [
          { "description": "设圆O的半径为 $r$，则 $PO = PB + r = 2 + r$" },
          { "description": "PA 是切线，所以 $OA \\perp PA$" },
          { "description": "由勾股定理：$PO^2 = PA^2 + OA^2$" },
          { "description": "$(2+r)^2 = 16 + r^2$" },
          { "description": "$4 + 4r + r^2 = 16 + r^2$" },
          { "description": "$4r = 12 \\implies r = 3$" }
        ],
        "keyKnowledge": "切线性质、勾股定理"
      }
    },
