    {
      "id": "phy-g8-ch03-q004",
      "type": "fill",
      "stem": "一束光从空气斜射入玻璃，入射角为 45°，折射角为 30°。若入射角增大到 60°，则折射角为多少度？",
      "segments": ["折射角为 ", "___1___", " 。"],
      "blanks": [{ "index": 1, "answer": "约 35.3°" }],
      "difficulty": 3,
      "topicId": "phy-g8-ch03-t04",
      "tags": ["提高题"],
      "solution": {
        "answer": "约 35.3°",
        "steps": [
          { "description": "由折射定律：$n_1 \\sin\\theta_1 = n_2 \\sin\\theta_2$" },
          { "description": "空气 $n_1 = 1$，玻璃 $n_2 \\approx 1.5$" },
          { "description": "$\\sin 60° = 1.5 \\times \\sin\\theta_2$" },
          { "description": "$\\sin\\theta_2 = \\dfrac{\\sin 60°}{1.5} = \\dfrac{0.866}{1.5} = 0.577$" },
          { "description": "$\\theta_2 = \\arcsin(0.577) \\approx 35.3°$" }
        ],
        "keyKnowledge": "折射定律（斯涅尔定律）"
      }
    },
