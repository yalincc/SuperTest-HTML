    {
      "id": "math-g7-ch01-q001",
      "type": "choice",
      "stem": "下列各数中，是负数的是（  ）",
      "options": [
        { "label": "A", "text": "$-(-3)$" },
        { "label": "B", "text": "$|-3|$" },
        { "label": "C", "text": "$-|{-3}|$" },
        { "label": "D", "text": "$(-3)^2$" }
      ],
      "answer": "C",
      "difficulty": 2,
      "topicId": "math-g7-ch01-t01",
      "tags": ["中考真题", "易错题"],
      "source": { "type": "zhongkao", "year": 2023, "province": "广东", "questionNumber": "第1题" },
      "solution": {
        "answer": "C",
        "steps": [
          { "description": "化简各选项", "expression": "A: -(-3)=3,\\quad B: |-3|=3,\\quad C: -|-3|=-3,\\quad D: (-3)^2=9" },
          { "description": "判断正负性：只有 C 的结果为负数" }
        ],
        "keyKnowledge": "绝对值、相反数、有理数的乘方"
      },
      "trapPoints": [
        {
          "description": "$-|-3|$ 容易与 $|-3|$ 混淆",
          "correctApproach": "先算绝对值 $|-3|=3$，再取相反数得 $-3$",
          "commonMistake": "误认为 $-|-3|=3$，忽略了外层的负号"
        }
      ],
      "ttsText": "下列各数中，是负数的是。A选项，负的负3。B选项，负3的绝对值。C选项，负的负3的绝对值。D选项，负3的平方。"
    },
    {
