      "solution": {
        "answer": "A",
        "steps": [
          { "description": "DE 是 AB 的垂直平分线，所以 $EA = EB$" },
          { "description": "设 $BE = x$，则 $EA = x$，$EC = 8 - x$" },
          { "description": "在 Rt△ACE 中：$AE^2 = AC^2 + EC^2$" },
