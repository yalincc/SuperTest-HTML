      "id": "math-g9-ch02-q004",
      "type": "choice",
      "stem": "如图，△ABC的内切圆圆心为I，切三边于D、E、F。若AB=7，BC=8，AC=9，则BD的长度为（  ）",
      "options": [
        { "label": "A", "text": "$3$" },
        { "label": "B", "text": "$3.5$" },
        { "label": "C", "text": "$4$" },
        { "label": "D", "text": "$4.5$" }
      ],
      "answer": "A",
      "difficulty": 3,
      "topicId": "math-g9-ch02-t01",
      "tags": ["提高题"],
      "figure": {
        "type": "construction",
        "padding": 1.5,
        "construction": [
          { "op": "point", "id": "B", "at": [0, 0] },
          { "op": "point", "id": "C", "at": [8, 0] },
          { "op": "point", "id": "A", "at": [2.67, 6.49] },
          { "op": "triangle", "points": ["A", "B", "C"], "labels": ["A", "B", "C"] },
          { "op": "incenter", "id": "I", "triangle": ["A", "B", "C"] },
          { "op": "circle", "id": "incircle", "center": "I", "radius": 2.22, "style": "dashed" },
          { "op": "segment", "from": "I", "to": "B", "style": "dashed" }
        ]
      },
      "solution": {
        "answer": "A",
        "steps": [
          { "description": "设内切圆切 AB 于 F，切 BC 于 D，切 AC 于 E" },
          { "description": "由切线长相等：$BF = BD$，$CD = CE$，$AE = AF$" },
          { "description": "设 $BF = BD = x$，则 $CD = 8-x$，$AF = 7-x$，$AE = 9-(8-x) = 1+x$" },
          { "description": "由 $AF = AE$：$7-x = 1+x$，解得 $x = 3$" },
          { "description": "所以 $BD = 3$" }
        ],
        "keyKnowledge": "内切圆切线长相等"
      }
    },
