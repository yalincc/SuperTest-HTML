      "stem": "下列物质中，由分子构成的是（  ）",
      "options": [
        { "label": "A", "text": "铁（Fe）" },
        { "label": "B", "text": "氯化钠（NaCl）" },
        { "label": "C", "text": "水（$\\text{H}_2\\text{O}$）" },
        { "label": "D", "text": "金刚石（C）" }
      ],
      "answer": "C",
      "difficulty": 1,
      "topicId": "chem-g9-ch01-t01",
      "tags": ["基础题", "中考真题"],
      "solution": {
        "answer": "C",
        "steps": [
          { "description": "由分子构成的物质：大多数非金属单质、非金属氧化物、酸、碱（部分）等" },
          { "description": "A、D 由原子直接构成，B 由离子构成，C 水由水分子构成" }
        ],
        "keyKnowledge": "物质的微观构成"
      }
    },
