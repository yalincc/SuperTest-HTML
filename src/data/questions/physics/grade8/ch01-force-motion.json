  "questions": [
    {
      "id": "phy-g8-ch01-q001",
      "type": "choice",
      "stem": "下列关于力的说法中，正确的是（  ）",
      "options": [
        { "label": "A", "text": "力是维持物体运动的原因" },
        { "label": "B", "text": "物体只有受力才能运动" },
        { "label": "C", "text": "力是改变物体运动状态的原因" },
        { "label": "D", "text": "物体不受力时一定静止" }
      ],
      "answer": "C",
      "difficulty": 2,
      "topicId": "phy-g8-ch01-t02",
      "tags": ["中考真题", "易错题", "高频考点"],
      "source": { "type": "zhongkao", "year": 2023, "province": "广东", "questionNumber": "第3题" },
      "solution": {
        "answer": "C",
        "steps": [
          { "description": "牛顿第一定律：物体在不受外力时，保持匀速直线运动或静止状态" },
          { "description": "力不是维持运动的原因，而是改变运动状态的原因" },
          { "description": "A、B 是亚里士多德的错误观点，D 忽略了匀速直线运动的情况" }
        ],
        "keyKnowledge": "牛顿第一定律的理解"
      },
      "trapPoints": [
        {
          "description": "误认为力是维持运动的原因",
          "correctApproach": "力是改变运动状态的原因，不受力时物体做匀速直线运动或保持静止",
          "commonMistake": "受日常经验影响，认为物体不受力就会停下来"
        }
      ]
    },
    {
      "id": "phy-g8-ch01-q002",
      "type": "choice",
      "stem": "一个重 50 N 的物体静止在水平桌面上，下列说法正确的是（  ）",
      "options": [
        { "label": "A", "text": "物体对桌面的压力就是物体的重力" },
        { "label": "B", "text": "桌面对物体的支持力与物体的重力是一对平衡力" },
        { "label": "C", "text": "物体对桌面的压力与桌面对物体的支持力是一对平衡力" },
        { "label": "D", "text": "桌面对物体的支持力大于物体的重力" }
      ],
      "answer": "B",
      "difficulty": 3,
      "topicId": "phy-g8-ch01-t03",
      "tags": ["中考真题", "易错题", "高频考点"],
      "source": { "type": "zhongkao", "year": 2022, "province": "江苏", "questionNumber": "第8题" },
      "solution": {
        "answer": "B",
        "steps": [
          { "description": "物体静止，处于平衡状态，合力为零" },
          { "description": "竖直方向上受重力和支持力，这两个力大小相等、方向相反、作用在同一物体上，是一对平衡力" },
          { "description": "A 错误：压力和支持力是作用力与反作用力，不是同一个力" },
          { "description": "C 错误：压力与支持力是相互作用力，不是平衡力（作用在不同物体上）" }
        ],
        "keyKnowledge": "二力平衡与相互作用力的区别"
      },
      "trapPoints": [
        {
          "description": "平衡力与相互作用力的区分",
          "correctApproach": "平衡力作用在同一物体上；相互作用力作用在两个物体上",
          "commonMistake": "把压力和支持力当作平衡力，忽略了它们作用在不同物体上"
        }
      ]
    },
