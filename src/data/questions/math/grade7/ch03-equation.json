    {
      "id": "math-g7-ch03-q011",
      "type": "choice",
      "stem": "某商品原价 100 元，连续两次降价后售价为 81 元，求平均每次降价的百分率。设平均每次降价的百分率为 $x$，则方程为（  ）",
      "options": [
        { "label": "A", "text": "$100(1-x)^2 = 81$" },
        { "label": "B", "text": "$100(1-2x) = 81$" },
        { "label": "C", "text": "$100 - 2 \\times 100x = 81$" },
        { "label": "D", "text": "$100(1+x)^2 = 81$" }
      ],
      "answer": "A",
      "difficulty": 3,
      "topicId": "math-g7-ch03-t03",
      "tags": ["提高题"],
      "solution": {
        "answer": "A",
        "steps": [
          { "description": "第一次降价后价格：$100(1-x)$" },
          { "description": "第二次降价后价格：$100(1-x)(1-x) = 100(1-x)^2$" },
          { "description": "根据题意：$100(1-x)^2 = 81$" }
        ],
        "keyKnowledge": "增长率问题——连续变化模型"
      }
    },
    {
      "id": "math-g7-ch03-q012",
      "type": "choice",
      "stem": "甲、乙两人共有 100 元，甲用去 20 元，乙用去 30 元后，两人剩下的钱数之比为 3:2。则甲、乙原来各有多少元？",
      "options": [
        { "label": "A", "text": "甲 50 元，乙 50 元" },
        { "label": "B", "text": "甲 60 元，乙 40 元" },
        { "label": "C", "text": "甲 70 元，乙 30 元" },
        { "label": "D", "text": "甲 80 元，乙 20 元" }
      ],
      "answer": "B",
      "difficulty": 3,
      "topicId": "math-g7-ch03-t03",
      "tags": ["提高题"],
      "solution": {
        "answer": "B",
        "steps": [
          { "description": "设甲原来有 $x$ 元，则乙有 $(100-x)$ 元" },
          { "description": "甲剩下 $(x-20)$ 元，乙剩下 $(70-x)$ 元" },
          { "description": "由比例：$\\dfrac{x-20}{70-x} = \\dfrac{3}{2}$" },
          { "description": "交叉相乘：$2(x-20) = 3(70-x)$" },
          { "description": "解得：$x = 60$，乙有 $40$ 元" }
        ],
        "keyKnowledge": "比例分配问题"
      }
    }
  ]
