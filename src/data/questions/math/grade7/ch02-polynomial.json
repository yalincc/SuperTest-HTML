      "tags": ["基础题"],
      "solution": {
        "answer": "$m + n = 5$",
        "steps": [
          { "description": "同类项：相同字母的指数相同" },
          { "description": "$x$ 的指数：$m = 2$" },
          { "description": "$y$ 的指数：$n = 3$" },
          { "description": "$m + n = 2 + 3 = 5$" }
        ],
        "keyKnowledge": "同类项的定义"
      }
    },
    {
      "id": "math-g7-ch02-q009",
      "type": "fill",
      "stem": "化简 $4(x - y) - 2(x + 3y)$ 的结果。",
      "segments": ["结果为 ", "___1___", " 。"],
      "blanks": [{ "index": 1, "answer": "$2x - 10y$" }],
      "difficulty": 3,
      "topicId": "math-g7-ch02-t03",
      "tags": ["提高题"],
      "solution": {
        "answer": "$2x - 10y$",
        "steps": [
          { "description": "去括号：$4(x-y) = 4x - 4y$" },
          { "description": "去括号：$-2(x+3y) = -2x - 6y$" },
          { "description": "合并：$4x - 4y - 2x - 6y = 2x - 10y$" }
        ],
        "keyKnowledge": "乘法分配律与去括号"
      }
    },
    {
      "id": "math-g7-ch02-q010",
      "type": "choice",
      "stem": "若 $A = 3x^2 - 2x + 1$，$B = x^2 + x - 3$，则 $A - B$ 的结果是（  ）",
      "options": [
        { "label": "A", "text": "$2x^2 - 3x + 4$" },
        { "label": "B", "text": "$2x^2 - x - 2$" },
        { "label": "C", "text": "$4x^2 - x - 2$" },
        { "label": "D", "text": "$2x^2 - 3x - 2$" }
      ],
      "answer": "A",
      "difficulty": 3,
      "topicId": "math-g7-ch02-t03",
      "tags": ["提高题"],
      "solution": {
        "answer": "A",
        "steps": [
          { "description": "$A - B = (3x^2 - 2x + 1) - (x^2 + x - 3)$" },
          { "description": "去括号：$= 3x^2 - 2x + 1 - x^2 - x + 3$" },
          { "description": "合并同类项：$= 2x^2 - 3x + 4$" }
        ],
        "keyKnowledge": "多项式的加减运算"
      }
    },
    {
      "id": "math-g7-ch02-q011",
      "type": "choice",
      "stem": "已知 $a - b = 3$，$b - c = 2$，则 $a - c$ 的值为（  ）",
      "options": [
        { "label": "A", "text": "$1$" },
        { "label": "B", "text": "$5$" },
        { "label": "C", "text": "$6$" },
        { "label": "D", "text": "$-1$" }
      ],
      "answer": "B",
      "difficulty": 3,
      "topicId": "math-g7-ch02-t02",
      "tags": ["提高题"],
      "solution": {
        "answer": "B",
        "steps": [
          { "description": "$a - c = (a - b) + (b - c)$" },
          { "description": "$= 3 + 2 = 5$" }
        ],
        "keyKnowledge": "整体代入思想"
      }
    },
    {
      "id": "math-g7-ch02-q012",
      "type": "choice",
      "stem": "若 $a + b = 5$，$ab = 3$，则 $(a - 2) + (b - 3)$ 的值为（  ）",
      "options": [
        { "label": "A", "text": "$0$" },
        { "label": "B", "text": "$1$" },
        { "label": "C", "text": "$2$" },
        { "label": "D", "text": "$5$" }
      ],
      "answer": "A",
      "difficulty": 3,
      "topicId": "math-g7-ch02-t02",
      "tags": ["提高题"],
      "solution": {
        "answer": "A",
        "steps": [
          { "description": "$(a-2) + (b-3) = a + b - 2 - 3 = a + b - 5$" },
          { "description": "将 $a + b = 5$ 代入" },
          { "description": "$= 5 - 5 = 0$" }
        ],
        "keyKnowledge": "整体代入思想"
      }
    }
  ]
