      "stem": "在数轴上，与原点距离为 $3$ 的点所表示的数是（  ）",
      "options": [
        { "label": "A", "text": "$3$" },
        { "label": "B", "text": "$-3$" },
        { "label": "C", "text": "$\\pm 3$" },
        { "label": "D", "text": "不能确定" }
      ],
      "answer": "C",
      "difficulty": 1,
      "topicId": "math-g7-ch01-t03",
      "tags": ["基础题", "高频考点"],
      "solution": {
        "answer": "C",
        "steps": [
          { "description": "数轴上与原点距离为 3 的点有两个", "expression": "x = 3 \\text{ 或 } x = -3" },
          { "description": "所以该点表示的数为 $\\pm 3$" }
        ],
        "keyKnowledge": "数轴上的点与实数的对应关系"
      }
    },
    {
      "id": "math-g7-ch01-q003",
      "type": "choice",
      "stem": "若 $|a| = -a$，则 $a$ 一定是（  ）",
      "options": [
        { "label": "A", "text": "正数" },
        { "label": "B", "text": "负数" },
        { "label": "C", "text": "非正数" },
        { "label": "D", "text": "非负数" }
      ],
      "answer": "C",
      "difficulty": 3,
      "topicId": "math-g7-ch01-t05",
      "tags": ["中考真题", "易错题", "高频考点"],
      "source": { "type": "zhongkao", "year": 2022, "questionNumber": "第3题" },
      "solution": {
        "answer": "C",
        "steps": [
          { "description": "绝对值的性质：$|a| \\geq 0$，所以 $-a \\geq 0$" },
          { "description": "因此 $a \\leq 0$，即 $a$ 是非正数（包括负数和0）" }
        ],
        "keyKnowledge": "绝对值的性质"
      },
      "trapPoints": [
        {
          "description": "容易忽略 $a=0$ 的情况",
          "correctApproach": "$|0| = 0 = -0$ 也满足条件，所以 $a$ 可以是 0",
          "commonMistake": "只考虑负数，选了B，漏掉了 $a=0$"
        }
      ]
    },
    {
