      "source": { "type": "zhongkao", "year": 2023, "province": "广东", "questionNumber": "第4题" },
      "solution": {
        "answer": "C",
        "steps": [
          { "description": "A 错误：原子可以再分为原子核和核外电子" },
          { "description": "B 错误：原子核由质子和中子组成" },
          { "description": "C 正确：原子不显电性，质子数 = 电子数" },
          { "description": "D 错误：普通氢原子核中没有中子" }
