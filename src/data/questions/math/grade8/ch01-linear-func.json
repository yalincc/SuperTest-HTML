      "topicId": "math-g8-ch01-t01",
      "tags": ["基础题"],
      "solution": {
        "answer": "B",
        "steps": [
          { "description": "一次函数的形式为 $y = kx + b$（$k \\neq 0$）" },
          { "description": "A 是二次函数，C 是反比例函数，D 是根式函数，只有 B 是一次函数" }
        ],
        "keyKnowledge": "一次函数的定义"
      }
